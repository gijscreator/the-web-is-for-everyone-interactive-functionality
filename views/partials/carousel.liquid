<ul class="carousel">
    {% for i in (1..4) %}
    <li id="step{{ i }}">
        <article class="card">
            {% case i %}
                {% when 1 %}
                    {% render 'partials/general-heading.liquid',
                        heading_level: 2,
                        content: titlestep1,
                    %}
                    <p>{{descriptionstep1}}</p>
                    {% if contentstep1 %}
                        <img src="{{ contentstep1 }}" class="{{ classstep1 }}" alt="{{altstep1}}">
                    {% endif %}

