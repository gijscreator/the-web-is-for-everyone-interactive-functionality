                        </svg>
                    {% elsif contentstep4 %}
                        <img src="{{ contentstep4 }}" alt="Garden">
                    {% endif %}
            {% endcase %}

            <nav class="controls">
                {%- if i > 1 -%} 
                    <a href="#step{{ i | minus: 1 }}" class="secondary styled">terug</a>
                {%- endif -%}

                <div class="dots">
                    {% for dot_index in (1..4) %}
                        <a href="#step{{ dot_index }}" class="dot{% if dot_index == i %} active{% endif %}"></a>
                    {% endfor %}
                </div>

                {%- if i < 4 -%}
                        <a href="#step{{ i | plus: 1 }}" class="primary styled">Volgende</a>
                    {%- else -%}
                        {%- if current_path contains 'welcome' -%}
                            {% comment %} If on the welcome page, show the popover button {% endcomment %}
                            <a href="/veldverkenner" class="styled klaar">Klaar</a>
                            
                        {%- else -%}
                            {% comment %} If elsewhere, show a link to the veldverkenner {% endcomment %}
                            <button class="styled klaar" popovertarget="uitleg">Klaar</button>
                        {%- endif -%}
                    {%- endif -%}
            </nav>
        </article>
    </li>
    {% endfor %}
</ul>