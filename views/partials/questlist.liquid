<ul class="quest">
    {% assign has_quests = false %}
    {% for plant in plants %}
        {% comment %} Only show the quest if the plant has one AND hasn't been collected yet {% endcomment %}
        {% if plant.quest and plant.is_completed == false %}
            {% assign has_quests = true %}
            <li>
                <section>
                    <article>
                        <div class="questionwrapper {{ zone_type }}">
                            <svg width="38" height="33" viewBox="0 0 38 33" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <g clip-path="url(#clip0_387_604)">
                                    <path d="M1.58301 16.5C1.58301 16.5 7.91634 5.5 18.9997 5.5C30.083 5.5 36.4163 16.5 36.4163 16.5C36.4163 16.5 30.083 27.5 18.9997 27.5C7.91634 27.5 1.58301 16.5 1.58301 16.5Z" stroke="#004121" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M18.9997 20.625C21.623 20.625 23.7497 18.7782 23.7497 16.5C23.7497 14.2218 21.623 12.375 18.9997 12.375C16.3763 12.375 14.2497 14.2218 14.2497 16.5C14.2497 18.7782 16.3763 20.625 18.9997 20.625Z" stroke="#004121" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                                </g>
                                <defs>
                                    <clipPath id="clip0_387_604">
                                        <rect width="38" height="33" fill="white"/>
                                    </clipPath>
                                </defs>
                            </svg>
                        </div>
                        <div class="headingwrapper">
                            <h3>{{ plant.quest.name }}</h3>
                            <p>+{{ plant.quest.xp }}xp</p>
                        </div>
                    </article>
                    
                    <p>{{ plant.quest.description | truncate: 120 }}</p>
                </section>

                <a class="styled quest card" href="/veldverkenner/{{ zone_slug }}/{{ plant.quest.slug }}">
                    Start deze opdracht
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 18L15 12L9 6" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
            </li>
        {% endif %}
    {% endfor %}

    {% if has_quests == false %}
        <li>Er zijn momenteel geen nieuwe opdrachten in deze zone.</li>
    {% endif %}
</ul>