{% assign parts = current_path | split: "/" %}
{% assign cumulative_path = "" %}

<nav class="breadcrumb-container">
    <ul class="breadcrumbs">
        {% for part in parts %}
            {% unless part == "" %}
                {% comment %} Build the path segment by segment {% endcomment %}
                {% assign cumulative_path = cumulative_path | append: "/" | append: part %}
                
                <li class="breadcrumb-item">
                    <a href="{{ cumulative_path }}" class="{% if forloop.last %}active{% endif %}">
                        {{ part | capitalize | replace: "-", " " | truncate: 30 }}
                    </a>
                    
                    {% unless forloop.last %}
                        <span class="separator">></span>
                    {% endunless %}
                </li>
            {% endunless %}
        {% endfor %}
    </ul>
</nav>